# Google Civic Information API
# Get at: console.cloud.google.com → Enable "Civic Information API" → Create API Key
GOOGLE_CIVIC_API_KEY=your_key_here

# ProPublica Congress API
# Get at: www.propublica.org/datastore/api/propublica-congress-api
PROPUBLICA_API_KEY=your_key_here

# OpenStates API (state legislators)
# Get at: openstates.org/accounts/register
OPENSTATES_API_KEY=your_key_here

# Congress.gov API (official federal bill text + summaries)
# Get at: api.congress.gov
CONGRESS_GOV_API_KEY=your_key_here

# Anthropic API (generates plain-English bill summaries when none exist)
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=your_key_here
