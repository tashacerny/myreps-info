# Google Civic Information API — zip code → representatives lookup
# Get at: console.cloud.google.com → Enable "Civic Information API" → Create API Key
GOOGLE_CIVIC_API_KEY=your_key_here

# Congress.gov API — all federal data: members, votes, bills, summaries
# Get at: api.congress.gov
CONGRESS_GOV_API_KEY=your_key_here

# OpenStates API — state legislators for all 50 states
# Get at: openstates.org/accounts/register
OPENSTATES_API_KEY=your_key_here

# Anthropic API — generates plain-English bill summaries when none exist in Congress.gov
# Get at: console.anthropic.com
ANTHROPIC_API_KEY=your_key_here
